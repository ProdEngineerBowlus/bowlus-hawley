# H.A.W.L.E. / Hawley local configuration

# Postgres
PGHOST=localhost
PGPORT=5432
PGDATABASE=bowlus_ops
PGUSER=bowlus_app
PGPASSWORD=
DATABASE_URL=postgres://bowlus_app:CHANGE_ME@localhost:5432/bowlus_ops
HAWLEY_SYNC_DATABASE_URL=

# Source-system credentials. Store values only in local .env files.
AIRTABLE_PAT=
AIRTABLE_BASE=
HAWLEY_AIRTABLE_TASKS_TABLE=Tasks
HAWLEY_AIRTABLE_PRODUCTION_TABLE=Production
HAWLEY_AIRTABLE_VINS_TABLE=VINs
HAWLEY_AIRTABLE_MODELS_TABLE=Models
ASANA_PAT=
HAWLEY_ASANA_FABRICATION_PORTFOLIO_GID=1212620750946278
HAWLEY_ASANA_VIN_PORTFOLIO_GID=1212620750946276
HAWLEY_ASANA_PORTFOLIO_SCOPE=both
HAWLEY_ASANA_PROJECT_TEMPLATE_GID=1211664083967075
HAWLEY_ADMIN_PROJECT_CREATE_ENABLED=false
HAWLEY_ADMIN_PLH_BASELINE_CYCLE=C5
HAWLEY_ADMIN_PLH_PHASES=
HAWLEY_ASANA_INCLUDE_SUBTASKS=true
HAWLEY_ASANA_SUBTASK_DEPTH=1
HAWLEY_ASANA_COMPLETED_SINCE=1970-01-01T00:00:00.000Z
HAWLEY_ASANA_EVENT_WATCH_IN_WEB=false
HAWLEY_ASANA_EVENT_INTERVAL_MS=60000
HAWLEY_ASANA_EVENT_BUILD_HB=true
HAWLEY_WORKER_ACTUALS_WATCH_IN_WEB=true
HAWLEY_AIRTABLE_BACKFILL_WINDOW_DAYS=2
HAWLEY_NIGHTLY_REFRESH_ENABLED=true
HAWLEY_NIGHTLY_REFRESH_TIME=01:00
HAWLEY_NIGHTLY_REFRESH_TIME_ZONE=America/Los_Angeles
HAWLEY_NIGHTLY_REFRESH_SCRIPT=pg:refresh-hawley-read-model
HAWLEY_NIGHTLY_AIRTABLE_BACKFILL_ENABLED=true
HAWLEY_NIGHTLY_AIRTABLE_BACKFILL_APPLY=true
HAWLEY_NIGHTLY_AIRTABLE_BACKFILL_SCRIPT=pg:backfill:airtable-worker-actuals
HAWLEY_NIGHTLY_AIRTABLE_BACKFILL_WINDOW_DAYS=2
HAWLEY_OPS_OWNER_HINTS_CSV=data/ops/work-area-owner-hints.csv
HAWLEY_WORKER_HOST=127.0.0.1
HAWLEY_WORKER_PORT=5273

# Account login is installed inactive by default. Leave false until ready to test.
HAWLEY_AUTH_ACTIVE=false
HAWLEY_AUTH_SEED_ROSTER_ON_START=true
HAWLEY_AUTH_SESSION_TTL_HOURS=12
HAWLEY_AUTH_MANAGER_EMAILS=
HAWLEY_AUTH_ADMIN_EMAILS=
HAWLEY_AUTH_BOOTSTRAP_ENABLED=false
HAWLEY_AUTH_BOOTSTRAP_EMAIL=
HAWLEY_AUTH_BOOTSTRAP_PASSWORD=

# Safety defaults
HAWLEY_DRY_RUN=true
HAWLEY_ALLOW_SOURCE_WRITES=false
